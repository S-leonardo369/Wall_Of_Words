{
  "name": "wall-of-words",
  "version": "1.0.0",
  "description": "Improve your vocabulary passively through your desktop wallpaper",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "postinstall": "node scripts/gen-assets.js",
    "gen-wallpapers": "node scripts/gen-wallpapers.js"
  },
  "build": {
    "appId": "com.wallofwords.app",
    "productName": "Wall of Words",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "electron-store": "^7.0.3",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "keywords": ["vocabulary", "wallpaper", "learning", "electron"],
  "author": "Wall of Words",
  "license": "MIT"
}
